{
  "server": {
    "host": "127.0.0.1",
    "port": 8787,
    "apiKeys": []
  },
  "debug": {
    "enabled": true,
    "traceRetention": 100
  },
  "limits": {
    "requestBodyBytes": 1000000
  },
  "fallbacks": {
    "agentContextExhaustedMessage": "It's dizzy."
  },
  "prompts": {
    "requestInstruction": "Produce exactly the next assistant reply for the provided chat history. Do not mention hidden deliberation, councils, or internal agents."
  },
  "virtualModels": {
    "council-qwen-review": {
      "description": "Oracle-style council backed by three internal reviewers",
      "synthesizerAgentId": "editor",
      "councilPrompts": {
        "oracleSynthesisTemplate": "You are the Oracle, speaking with one unified voice for the council.\n\nPrivate deliberation from council members:\n{{privateThoughts}}\n\nAnswer with one direct, technically concrete response:"
      },
      "runtime": {
        "maxRounds": 2,
        "maxAgentReplies": 3,
        "agentSelectionStrategy": "all_in_order",
        "oracleSpeakerStrategy": "first_active"
      },
      "agents": [
        {
          "id": "editor",
          "name": "Editor",
          "summary": "Synthesizes discussion into one final answer",
          "systemPrompt": "You synthesize technical discussion into one clean final response.",
          "documents": [
            {
              "path": "../../docs/API.md",
              "description": "Core API reference"
            },
            {
              "path": "../../docs/CONTRACT.md",
              "description": "Contract and record model"
            }
          ],
          "engine": {
            "provider": "http://localhost:5815",
            "model": "Qwen3.5-27B",
            "contextWindow": 12288,
            "charsPerToken": 4,
            "promptBudgetRatio": 0.55,
            "promptSummaryPolicy": {
              "maxMessagesPerGroup": 3,
              "minGroupSnippetChars": 24,
              "minMessageSnippetChars": 18,
              "shrinkTargetRatio": 0.95
            },
            "settings": {
              "temperature": 0
            },
            "timeoutMs": 90000
          }
        },
        {
          "id": "architect",
          "name": "Architect",
          "summary": "Focuses on architecture and system boundaries",
          "systemPrompt": "You analyze architecture and boundaries. Respond concisely and concretely.",
          "engine": {
            "provider": "http://localhost:5815",
            "model": "Qwen3.5-27B",
            "contextWindow": 8192,
            "charsPerToken": 4,
            "settings": {
              "temperature": 0.1
            },
            "timeoutMs": 90000
          }
        },
        {
          "id": "reviewer",
          "name": "Reviewer",
          "summary": "Focuses on correctness and regressions",
          "systemPrompt": "You review behavior critically. Respond concisely and concretely.",
          "documents": [
            {
              "path": "../../docs/CONTRACT.md",
              "description": "Contract and record model"
            }
          ],
          "engine": {
            "provider": "http://localhost:5815",
            "model": "Qwen3.5-27B",
            "contextWindow": 6144,
            "charsPerToken": 4,
            "settings": {
              "temperature": 0.1
            },
            "timeoutMs": 90000
          }
        }
      ]
    }
  }
}
